@model FirstERP.Web.ViewModels.PagedCategoriesViewModel

<div class="toolbar">
    <a class="btn btn-primary" asp-action="Create">Add Category</a>
</div>

@if (TempData["SuccessMessage"] is string message)
{
    <div class="alert-success">@message</div>
}

<table class="erp-table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Description</th>
        </tr>
    </thead>
    <tbody>
    @if (Model.Items.Count == 0)
    {
        <tr>
            <td colspan="2">No categories available.</td>
        </tr>
    }
    else
    {
        foreach (var item in Model.Items)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Description</td>
            </tr>
        }
    }
    </tbody>
</table>

<div class="pager">
    <a class="btn btn-secondary @(Model.CurrentPage == 1 ? "disabled" : string.Empty)"
       asp-action="Index"
       asp-route-page="@(Model.CurrentPage - 1)">Previous</a>

    <span>Page @Model.CurrentPage of @Model.TotalPages</span>

    <a class="btn btn-secondary @(Model.CurrentPage >= Model.TotalPages ? "disabled" : string.Empty)"
       asp-action="Index"
       asp-route-page="@(Model.CurrentPage + 1)">Next</a>
</div>
